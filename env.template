# PostgreSQL設定
POSTGRES_DB=dentalDB
POSTGRES_USER=postgres
# 初回のみ: 既存の postgres_data ボリュームがある場合、初回起動時のパスワードが .env と一致しないことがあります。
# ホストからの接続で password authentication failed になる場合は setup/scripts/align-postgres-password-with-env.ps1 を実行するか、
# docker exec postgres_db psql -U postgres -d postgres -c "ALTER USER postgres WITH PASSWORD '...';" で揃えてください。
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# pgAdmin設定（オプション）
# PGADMIN_EMAIL: ログイン時のユーザー名（有効なメールアドレス形式である必要があります。@記号を含む必要があります）
# 例: admin@example.com
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password_here
PGADMIN_PORT=5050

